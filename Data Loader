"""Data loading and preprocessing utilities."""

import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
import warnings
warnings.filterwarnings('ignore')

class DataLoader:
    """Load and preprocess agricultural data."""
    
    def __init__(self, random_state=42):
        """Initialize DataLoader.
        
        Args:
            random_state: Random seed for reproducibility
        """
        self.random_state = random_state
        self.scaler = StandardScaler()
        self.data = None
        self.X_train = None
        self.X_val = None
        self.X_test = None
        self.y_train = None
        self.y_val = None
        self.y_test = None
    
    def load_data(self, filepath):
        """Load agricultural data from CSV.
        
        Args:
            filepath: Path to CSV file
            
        Returns:
            DataFrame with loaded data
        """
        print(f"Loading data from {filepath}...")
        self.data = pd.read_csv(filepath)
        print(f"Data shape: {self.data.shape}")
        print(f"\nFirst few rows:\n{self.data.head()}")
        return self.data
    
    def explore_data(self):
        """Explore and display data statistics."""
        if self.data is None:
            raise ValueError("Load data first using load_data()")
        
        print("\n" + "="*60)
        print("DATA EXPLORATION REPORT")
        print("="*60)
        
        print("\nBasic Statistics:")
        print(self.data.describe())
        
        print("\nMissing Values:")
        missing = self.data.isnull().sum()
        if missing.sum() > 0:
            print(missing[missing > 0])
        else:
            print("No missing values found!")
        
        print("\nData Types:")
        print(self.data.dtypes)
        
        print("\nCorrelation Matrix:")
        numeric_data = self.data.select_dtypes(include=[np.number])
        print(numeric_data.corr())
    
    def handle_missing_values(self, method='mean', threshold=0.5):
        """Handle missing values in dataset.
        
        Args:
            method: 'mean', 'median', or 'drop'
            threshold: Drop columns if missing ratio > threshold
        """
        if self.data is None:
            raise ValueError("Load data first using load_data()")
        
        print(f"\nHandling missing values using {method} method...")
        
        # Drop columns with too many missing values
        missing_ratio = self.data.isnull().sum() / len(self.data)
        cols_to_drop = missing_ratio[missing_ratio > threshold].index
        
        if len(cols_to_drop) > 0:
            print(f"Dropping columns: {cols_to_drop.tolist()}")
            self.data = self.data.drop(columns=cols_to_drop)
        
        # Handle remaining missing values
        if method == 'mean':
            numeric_cols = self.data.select_dtypes(include=[np.number]).columns
            self.data[numeric_cols] = self.data[numeric_cols].fillna(
                self.data[numeric_cols].mean()
            )
        elif method == 'median':
            numeric_cols = self.data.select_dtypes(include=[np.number]).columns
            self.data[numeric_cols] = self.data[numeric_cols].fillna(
                self.data[numeric_cols].median()
            )
        elif method == 'drop':
            self.data = self.data.dropna()
        
        print(f"Missing values after handling: {self.data.isnull().sum().sum()}")
    
    def prepare_features(self, target_column='Yield', drop_columns=None):
        """Prepare features and target variable.
        
        Args:
            target_column: Name of target column
            drop_columns: Columns to exclude
            
        Returns:
            Tuple of (X, y) - features and target
        """
        if self.data is None:
            raise ValueError("Load data first using load_data()")
        
        print("\nPreparing features...")
        
        df = self.data.copy()
        
        if target_column not in df.columns:
            raise ValueError(f"Target column '{target_column}' not found")
        
        y = df[target_column].values
        X = df.drop(columns=[target_column])
        
        if drop_columns:
            X = X.drop(columns=[col for col in drop_columns if col in X.columns])
        
        print(f"Feature matrix shape: {X.shape}")
        print(f"Target variable shape: {y.shape}")
        
        return X, y
    
    def normalize_features(self, X_train, X_val=None, X_test=None, fit=True):
        """Normalize features using StandardScaler.
        
        Args:
            X_train: Training features
            X_val: Validation features
            X_test: Test features
            fit: Whether to fit scaler on training data
            
        Returns:
            Normalized feature arrays
        """
        print("\nNormalizing features...")
        
        if fit:
            X_train = self.scaler.fit_transform(X_train)
        else:
            X_train = self.scaler.transform(X_train)
        
        if X_val is not None:
            X_val = self.scaler.transform(X_val)
        
        if X_test is not None:
            X_test = self.scaler.transform(X_test)
        
        print("Normalization complete!")
        return X_train, X_val, X_test
    
    def split_data(self, X, y, test_size=0.2, val_size=0.2):
        """Split data into train, validation, and test sets.
        
        Args:
            X: Feature matrix
            y: Target variable
            test_size: Proportion for test set
            val_size: Proportion for validation set
            
        Returns:
            Tuple of (X_train, X_val, X_test, y_train, y_val, y_test)
        """
        print("\nSplitting data into train/val/test sets...")
        
        X_temp, X_test, y_temp, y_test = train_test_split(
            X, y, test_size=test_size, random_state=self.random_state
        )
        
        X_train, X_val, y_train, y_val = train_test_split(
            X_temp, y_temp, test_size=val_size, random_state=self.random_state
        )
        
        print(f"Training set: {X_train.shape}")
        print(f"Validation set: {X_val.shape}")
        print(f"Test set: {X_test.shape}")
        
        X_train_norm, X_val_norm, X_test_norm = self.normalize_features(
            X_train, X_val, X_test, fit=True
        )
        
        self.X_train = X_train_norm
        self.X_val = X_val_norm
        self.X_test = X_test_norm
        self.y_train = y_train
        self.y_val = y_val
        self.y_test = y_test
        
        return X_train_norm, X_val_norm, X_test_norm, y_train, y_val, y_test
